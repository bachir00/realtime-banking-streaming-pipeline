# ============================================================
# Copy this file to .env and fill in your own values.
# Never commit .env to version control — only .env.example.
# In Docker, host addresses are replaced by service names
# (e.g., kafka, postgres). This file is intended for local
# development outside of Docker.
# ============================================================

# ------------------------------------------------------------
# Kafka
# ------------------------------------------------------------
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC=transactions
KAFKA_GROUP_ID=postgres-consumer-group
KAFKA_AUTO_OFFSET_RESET=latest           # Options: latest | earliest

# ------------------------------------------------------------
# PostgreSQL
# ------------------------------------------------------------
DB_HOST=localhost
DB_PORT=5432
DB_NAME=banking_db
DB_USER=your_db_user
DB_PASSWORD=your_db_password

# ------------------------------------------------------------
# AWS (required for S3 storage)
# ------------------------------------------------------------
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here
AWS_DEFAULT_REGION=us-east-1             # e.g., us-east-1 | eu-west-1
S3_BUCKET=your_s3_bucket_name

# ------------------------------------------------------------
# Producer
# ------------------------------------------------------------
TRANSACTION_INTERVAL_SEC=1               # Delay (seconds) between transactions
TRANSACTIONS_PER_SECOND=5               # Number of transactions generated per second

# ------------------------------------------------------------
# Fraud Detection
# ------------------------------------------------------------
FRAUD_AMOUNT_THRESHOLD=3000             # Transactions above this are flagged as suspicious
HIGH_VALUE_THRESHOLD=4000               # Transactions above this trigger a high-value alert

# ------------------------------------------------------------
# Grafana (optional — only if using the dashboard)
# ------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=your_grafana_password
